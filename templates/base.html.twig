<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Bibliothèque{% endblock %}</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-50 text-gray-800">

    <nav class="bg-white border-b border-gray-200 px-6 py-4">
        <div class="max-w-3xl mx-auto flex items-center justify-between">
            <a href="{{ path('app_livre_index') }}" class="font-bold text-gray-900">
                📚 Bibliothèque
            </a>
            <div class="flex gap-4">
                <a href="{{ path('app_auteur_index') }}"
                   class="text-sm text-gray-500 hover:text-gray-900">
                    Auteurs
                </a>
                <a href="{{ path('app_livre_new') }}"
                   class="bg-gray-900 text-white text-sm px-4 py-2 rounded-lg hover:bg-gray-700">
                    + Nouveau livre
                </a>
            </div>
        </div>
    </nav>

    <div class="max-w-3xl mx-auto px-6 py-8">

        {% for message in app.flashes('success') %}
            <div class="bg-green-100 text-green-800 border border-green-200 rounded-xl px-5 py-3 mb-6 text-sm font-medium">
                ✅ {{ message }}
            </div>
        {% endfor %}

        {% block body %}{% endblock %}

    </div>

</body>
</html>