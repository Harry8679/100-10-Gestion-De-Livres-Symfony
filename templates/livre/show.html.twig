{% extends 'base.html.twig' %}

{% block title %}{{ livre.titre }}{% endblock %}

{% block body %}

<a href="{{ path('app_livre_index') }}"
   class="text-sm text-gray-400 hover:text-gray-700 mb-8 inline-block">
    ← Retour à la bibliothèque
</a>

<div class="bg-white border border-gray-200 rounded-2xl p-8">

    <div class="flex items-start justify-between mb-6">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">{{ livre.titre }}</h1>
            {% if livre.anneePublication %}
                <p class="text-gray-400 text-sm mt-1">Publié en {{ livre.anneePublication }}</p>
            {% endif %}
        </div>

        <div class="flex gap-3 flex-shrink-0">
            <a href="{{ path('app_livre_edit', { id: livre.id }) }}"
               class="border border-gray-300 text-gray-600 text-sm px-4 py-2 rounded-lg hover:bg-gray-50">
                Modifier
            </a>
            <a href="{{ path('app_livre_delete', { id: livre.id }) }}"
               class="border border-red-200 text-red-400 text-sm px-4 py-2 rounded-lg hover:bg-red-50"
               onclick="return confirm('Supprimer ce livre ?')">
                Supprimer
            </a>
        </div>
    </div>

    {# ── Section Auteurs ─── #}
    <div class="mb-6 pb-6 border-b border-gray-100">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Auteur(s)</h2>
        {% if livre.auteurs is not empty %}
            <div class="flex flex-wrap gap-2">
                {# On parcourt la Collection Doctrine — exactement comme un tableau PHP #}
                {% for auteur in livre.auteurs %}
                    <span class="bg-gray-900 text-white text-sm font-medium px-3 py-1.5 rounded-full">
                        {{ auteur.nom }}
                    </span>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-gray-400 text-sm italic">Aucun auteur associé.</p>
        {% endif %}
    </div>

    {# ── Description ─── #}
    {% if livre.description %}
        <div>
            <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Description</h2>
            <p class="text-gray-600 leading-relaxed text-sm">{{ livre.description }}</p>
        </div>
    {% endif %}

    <p class="text-xs text-gray-300 mt-8">
        Ajouté le {{ livre.createdAt|date('d/m/Y') }}
    </p>

</div>

{% endblock %}